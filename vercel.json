{
  "version": 2,
  "builds": [
    {
      "src": "server/src/index.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "server/src/index.js"
    },
    {
      "src": "/api-docs/(.*)",
      "dest": "server/src/index.js"
    },
    {
      "src": "/api-docs",
      "dest": "server/src/index.js"
    }
  ]
}
